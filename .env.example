# Postgres (used by docker-compose to initialize the database container)
POSTGRES_USER=massa
POSTGRES_PASSWORD=massa
POSTGRES_DB=massa

# Backend
PORT=8080
DATABASE_URL=postgres://massa:massa@postgres:5432/massa?sslmode=disable
APP_BASE_URL=http://localhost:3000

# Session cookies
COOKIE_SIGNING_SECRET=changeme-32-byte-random-secret
COOKIE_SECURE=false

# Encryption key for stored Google OAuth tokens (AES-256-GCM, 32 bytes)
OAUTH_TOKEN_ENCRYPTION_KEY=changeme-32-byte-random-key

# Google OAuth2 (see docs/GOOGLE_HEALTH_SETUP.md)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/api/google/callback

# Email delivery for magic links: "resend", "smtp", or "ses"
# Local dev: "smtp" with Mailpit (see docker-compose.yml) — view emails at http://localhost:8025
# Production: "ses" (AWS SES SMTP) — see docs/AWS_SES_SETUP.md
EMAIL_PROVIDER=smtp
RESEND_API_KEY=
SES_REGION=
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
MAGIC_LINK_FROM_EMAIL=login@massa.local

# Comma-separated list of emails allowed to log in
ALLOWED_EMAILS=you@example.com

# How often the background sync job pulls new Google Health data
SYNC_INTERVAL_HOURS=12

# Frontend
NUXT_PUBLIC_API_BASE=http://localhost:8080
